# Example environment variables for the Attention Economy Revenue Simulator.
# If you need to add secrets later, keep them in a local .env file only.
# This project currently does not depend on any required environment variables.

PORT=3000
FRONTEND_PORT=3000
NODE_ENV=production

# API Configuration - Use Docker service name, not localhost
# This ensures container-to-container communication via Docker DNS
NEXT_PUBLIC_API_URL=http://backend:8000

BACKEND_PORT=8000
ENVIRONMENT=docker
DATABASE_URL=postgresql://postgres:postgres@db:5432/poc45
SECRET_API_KEY=your-secret-key-here
CORS_ORIGINS=http://localhost:3000,http://frontend:3000
NEXT_PUBLIC_ANALYTICS_ID=
